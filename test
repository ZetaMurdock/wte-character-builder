const BG_STANDARD = [2,2,1,1];
const BG_FOCUSED  = [4,2];

const ATTRS = [['a-phy','PHY'],['a-dex','DEX'],['a-end','END'],['a-ap','AP'],['a-wis','WIS'],['a-con','CON'],['a-int','INT']];
const SPECS = [['s-ins','Inspiration'],['s-ver','Versatility'],['s-bal','Balance'],['s-wt','Weight'],['s-pre','Precision'],['s-ctrl','Control'],['s-pri','Priority'],['s-wm','Wpn Mastery'],['s-mf','Mental Fort.'],['s-per','Perception'],['s-adp','Adaption'],['s-cun','Cunning']];
// reducing specialties (Tax Burden contributors) — kept in sync with the derived web
const REDUCERS = ['s-pre','s-bal','s-adp','s-cun','s-wt','s-ver','s-pri','s-mf','s-ctrl','s-wm','s-per'];

const STAT_OPTIONS = [
  {id:'a-phy',label:'PHY'},{id:'a-dex',label:'DEX'},{id:'a-end',label:'END'},
  {id:'a-ap',label:'AP'},{id:'a-wis',label:'WIS'},{id:'a-con',label:'CON'},{id:'a-int',label:'INT'},
  {id:'s-ins',label:'Inspiration'},{id:'s-ver',label:'Versatility'},{id:'s-bal',label:'Balance'},
  {id:'s-wt',label:'Weight'},{id:'s-pre',label:'Precision'},{id:'s-ctrl',label:'Control'},
  {id:'s-pri',label:'Priority'},{id:'s-wm',label:'Wpn Mastery'},{id:'s-mf',label:'Mental Fort.'},
