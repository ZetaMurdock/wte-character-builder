<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>W.T.E Character Sheet</title>
<style>
:root {
  --bg: #4c4843;          /* darker boney grey page */
  --bg2: #413e39;
  --page-ink: #e7e2d8;    /* light text on dark page */
  --surface: #ffffff;
  --surface2: #eeece9;
  --border: #c8c4bf;
  --border2: #a8a49f;
  --ink: #1c1b19;
  --ink2: #3d3c39;
  --muted: #7a756e;
  --input-bg: #fafaf8;
  --rule: #2c3e50;
  --info-bg: #f0ede8;
  --bone: #cfc8ba;
  --accent: #8a6d3b;
}
* { box-sizing: border-box; margin: 0; padding: 0; border-radius: 0 !important; }
body {
  background: var(--bg);
  background-image: linear-gradient(180deg,var(--bg) 0%,var(--bg2) 100%);
  color: var(--ink);
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: 13px;
  line-height: 1.5;
  padding: 16px;
}

/* TOPBAR */
.topbar {
  display: flex; align-items: baseline; justify-content: space-between;
  padding-bottom: 8px; margin-bottom: 16px;
  border-bottom: 2px solid var(--bone);
}
.title { font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: var(--page-ink); font-weight: normal; }
.topbar-right { display: flex; gap: 5px; align-items: center; }
.btn {
  padding: 3px 10px; border: 1px solid var(--bone);
  background: none; color: var(--page-ink); cursor: pointer;
  font-size: 10px; font-family: 'Georgia', serif;
  letter-spacing: 1.5px; text-transform: uppercase; transition: all 0.1s;
}
.btn:hover { background: var(--bone); color: var(--ink); border-color: var(--bone); }
.btn.prime { background: var(--accent); border-color: var(--accent); color: #fff; }
.btn.prime:hover { background: #a07f44; border-color: #a07f44; }
.sep { color: var(--bone); font-size: 10px; opacity: 0.5; }

/* LAYOUT */
.sheet { display: flex; flex-direction: column; gap: 12px; }
.row { display: flex; gap: 10px; }
.row > * { flex: 1; }

/* SECTION */
.section { border: 1px solid var(--border2); background: var(--surface); }
.section-head {
  background: var(--rule); color: white;
  font-family: 'Georgia', serif; font-size: 9px;
  letter-spacing: 3px; text-transform: uppercase;
  padding: 5px 14px; font-weight: normal;
  display: flex; align-items: center; overflow: visible;
  position: relative;
}
.section-head::before { content: ''; position: absolute; left: -10px; top: 50%; width: 10px; height: 1px; background: rgba(255,255,255,0.45); }
.section-head::after  { content: ''; position: absolute; right: -10px; top: 50%; width: 10px; height: 1px; background: rgba(255,255,255,0.45); }
.section-head span { color: rgba(255,255,255,0.5); margin-left: 6px; font-size: 8px; letter-spacing: 1px; font-weight:normal; }
.section-body { padding: 10px 12px; }

/* INPUTS */
input[type="text"], input[type="number"], textarea, select {
  background: var(--input-bg); border: none;
  border-bottom: 1px solid var(--border);
  color: var(--ink); padding: 2px 4px;
  width: 100%; font-size: 12px; font-family: 'Georgia', serif;
  outline: none; transition: border-color 0.1s;
}
input:focus, textarea:focus, select:focus { border-bottom-color: var(--ink); }
input[type="number"] { text-align: center; }
input[readonly] { color: var(--muted); background: transparent; }
textarea { resize: vertical; border: 1px solid var(--border); }
.field { margin-bottom: 6px; }
.field:last-child { margin-bottom: 0; }
.field label {
  display: block; font-size: 8px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--muted);
  font-family: 'Georgia', serif; margin-bottom: 2px;
}

/* IDENTITY */
.ig1 { display: grid; grid-template-columns: 2fr 0.6fr 1fr 1fr 1fr 1fr; gap: 9px; margin-bottom: 6px; }
.ig2 { display: grid; grid-template-columns: 1fr 1fr 1fr 1.5fr; gap: 9px; }

/* INFO BOXES */
.info-box {
  background: var(--info-bg); border: 1px solid var(--border);
  padding: 8px 12px; margin-top: 8px; display: none;
}
.info-box.visible { display: block; }
.info-row { display: flex; gap: 16px; flex-wrap: wrap; }
.info-label { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); font-family: 'Georgia', serif; }
.info-value { font-size: 12px; color: var(--ink); }

/* SPECIES BOX */
.spec-bonus-tags { display: flex; gap: 6px; flex-wrap: wrap; margin: 6px 0; }
.sbtag { background: var(--surface2); border: 1px solid var(--border2); padding: 2px 8px; font-size: 11px; color: var(--ink); }
.sbtag b { color: var(--accent); }
.ability-chip-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
.ability-chip { background: #fff; border: 1px solid var(--border2); padding: 2px 7px; font-size: 10.5px; color: var(--ink2); }
.ability-chip.variant { border-color: var(--accent); color: var(--accent); }

/* BACKGROUND BONUS */
.bg-bonus-row { display: flex; gap: 8px; align-items: end; flex-wrap: wrap; margin-top: 8px; }
.bg-bonus-item { display: flex; gap: 4px; align-items: center; }
.bg-bonus-val { font-size: 11px; font-weight: bold; color: var(--ink); min-width: 22px; font-family: Georgia; }
.bg-bonus-item select { width: 110px; }

/* STAT TABLES */
.stat-table { width: 100%; border-collapse: collapse; }
.stat-table th {
  font-size: 8px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); font-family: 'Georgia', serif; font-weight: normal;
  text-align: left; padding: 3px 4px; border-bottom: 1px solid var(--border2);
}
.stat-table th.c { text-align: center; }
.stat-table td { padding: 2px 4px; border-bottom: 1px solid var(--border); vertical-align: middle; }
.stat-table tr:last-child td { border-bottom: none; }
.stat-table td.sn { font-size: 12px; }
.stat-table td.ss { font-size: 9px; color: var(--muted); }
.stat-table td.c { text-align: center; }
.stat-table input[type="number"] { width: 46px; font-size: 13px; }
.stat-table input.mod { width: 40px; font-size: 12px; }
.bonus-pip { font-size: 9px; color: var(--accent); margin-left: 2px; }

/* DICE ROLL BUTTON — tiny circular */
.roll-btn {
  display: inline-flex; align-items: center; justify-content: center;
  width: 15px; height: 15px; border-radius: 50% !important;
  border: 1px solid var(--border2); background: var(--surface2);
  color: var(--muted); cursor: pointer;
  font-size: 8px; line-height: 1; text-align: center;
  font-family: Georgia; vertical-align: middle;
  margin-left: 4px; transition: all 0.1s; flex-shrink: 0; padding: 0;
}
.roll-btn:hover { background: var(--accent); color: white; border-color: var(--accent); transform: scale(1.12); }
.stat-table .score-cell { display: flex; align-items: center; justify-content: center; }

/* HP ROW */
.hp-row {
  display: flex; align-items: center; gap: 8px;
  margin-top: 7px; padding-top: 7px; border-top: 1px solid var(--border);
  flex-wrap: wrap;
}
.hp-lbl { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); white-space: nowrap; font-family: Georgia; }
.hp-row input { width: 52px; font-size: 13px; }
.formula-note { font-size: 9px; color: var(--muted); font-style: italic; margin-top: 2px; }

/* RANK INFO */
.rank-bar {
  background: var(--info-bg); border: 1px solid var(--border);
  padding: 5px 10px; margin-top: 0;
  font-size: 9px; color: var(--muted); display: flex; gap: 14px; flex-wrap: wrap;
}
.rank-bar strong { color: var(--ink); }

/* INCEPT */
.incept-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; }
.stage-btns { display: flex; gap: 4px; margin-top: 2px; }
.stage-btn {
  flex: 1; padding: 3px; border: 1px solid var(--border2);
  background: none; color: var(--muted); cursor: pointer;
  font-size: 8px; letter-spacing: 1.5px; text-transform: uppercase;
  font-family: 'Georgia', serif; text-align: center; transition: all 0.1s;
}
.stage-btn.active { background: var(--ink); border-color: var(--ink); color: white; }

/* DATA TABLES */
.data-table { width: 100%; border-collapse: collapse; }
.data-table th {
  font-size: 8px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); font-family: 'Georgia', serif; font-weight: normal;
  text-align: left; padding: 3px 5px; border-bottom: 1px solid var(--border2);
  background: var(--surface2);
}
.data-table td { padding: 2px 4px; border-bottom: 1px solid var(--border); vertical-align: middle; }
.data-table tr:last-child td { border-bottom: none; }
.data-table td.rn { font-size: 9px; color: var(--muted); width: 16px; text-align: center; font-family: Georgia; }
.data-table input, .data-table select, .data-table textarea { font-size: 11px; padding: 2px 3px; }
.data-table textarea { min-height: 24px; }
.add-row-btn {
  margin-top: 4px; padding: 3px 10px; border: 1px dashed var(--border2);
  background: none; color: var(--muted); cursor: pointer;
  font-size: 8px; letter-spacing: 1.5px; text-transform: uppercase;
  font-family: 'Georgia', serif; display: block; width: 100%; transition: all 0.1s;
}
.add-row-btn:hover { border-color: var(--ink); color: var(--ink); }
.add-row-btn:disabled { opacity: 0.35; cursor: default; }

/* VARNA */
.vsub {
  font-size: 8px; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--muted); font-family: 'Georgia', serif;
  padding: 4px 0; border-bottom: 1px solid var(--border);
  margin-bottom: 7px; margin-top: 10px;
}
.vsub:first-child { margin-top: 0; }
.vgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.alist { display: flex; flex-direction: column; gap: 3px; }
.aitem { display: flex; gap: 4px; align-items: center; }
.anum { font-size: 9px; color: var(--muted); min-width: 14px; font-family: Georgia; }

/* CIPHER */
.cgrid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 7px; }
.cstatus { display: flex; gap: 4px; margin-top: 2px; }
.csbtn {
  flex: 1; padding: 3px; border: 1px solid var(--border2);
  background: none; color: var(--muted); cursor: pointer;
  font-size: 8px; letter-spacing: 1.5px; text-transform: uppercase;
  font-family: 'Georgia', serif; text-align: center; transition: all 0.1s;
}
.csbtn.active { background: var(--ink); border-color: var(--ink); color: white; }

/* PRESSURE ENGINE */
.pe-top { display: grid; grid-template-columns: 130px 1fr 1fr 1fr; gap: 10px; align-items: end; margin-bottom: 8px; }
.pe-state { font-size: 13px; font-weight: bold; font-family: Georgia; }
.pe-state.calm { color: #3a8050; }
.pe-state.tense { color: #b88a20; }
.pe-state.critical { color: #b03020; }
.pe-state.catastrophic { color: #7a1a1a; }
.pe-mini { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
.pe-mini b { color: var(--ink); font-size: 12px; }
.pe-skill-row { display: grid; grid-template-columns: 18px 1.4fr 1fr 70px; gap: 7px; align-items: center; margin-bottom: 5px; }
.pe-skill-row .rl { font-size: 9px; color: var(--muted); text-align: center; }
.pe-roll-out { font-size: 12px; font-family: Consolas, monospace; color: var(--ink2); text-align: center; }
.pe-actions { display: flex; gap: 8px; margin-top: 8px; align-items: center; }
.pe-resolve { padding: 6px 16px; border: 1px solid var(--accent); background: var(--accent); color: #fff; font-family: Georgia; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; }
.pe-resolve:hover { background: #a07f44; }
.pe-result {
  margin-top: 9px; background: var(--info-bg); border: 1px solid var(--border);
  padding: 10px 12px; display: none; gap: 18px; align-items: center; flex-wrap: wrap;
}
.pe-result.show { display: flex; }
.pe-res-item { display: flex; flex-direction: column; gap: 1px; }
.pe-res-lbl { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
.pe-res-val { font-size: 18px; font-family: Georgia; color: var(--ink); }
.pe-outcome { font-size: 15px; font-weight: bold; font-family: Georgia; }
.pe-apply { padding: 4px 12px; border: 1px solid var(--ink); background: none; color: var(--ink); font-family: Georgia; font-size: 9px; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; }
.pe-apply:hover { background: var(--ink); color: #fff; }

/* EQUIPMENT */
.ewpn { display: grid; grid-template-columns: 2fr 65px 75px; gap: 6px; margin-bottom: 5px; align-items: end; }
.earm { display: grid; grid-template-columns: 2fr 65px; gap: 6px; align-items: end; }
.wpn-type-hint { font-size: 9px; color: var(--muted); font-style: italic; margin-bottom: 4px; }

/* DICE PANEL */
.dice-panel {
  position: fixed; right: 0; top: 0; bottom: 0; width: 258px;
  background: var(--surface); border-left: 1px solid var(--border2);
  z-index: 999; transform: translateX(100%); transition: transform 0.2s ease;
  display: flex; flex-direction: column;
}
.dice-panel.open { transform: translateX(0); }
.dp-head {
  background: var(--rule); padding: 8px 12px;
  display: flex; align-items: center; justify-content: space-between;
}
.dp-title { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: white; font-family: 'Georgia', serif; }
.dp-close { background: none; border: none; color: rgba(255,255,255,0.5); cursor: pointer; font-size: 15px; font-family: Georgia; }
.dp-close:hover { color: white; }
.dp-body { flex: 1; overflow-y: auto; padding: 10px 12px; display: flex; flex-direction: column; gap: 9px; }
.dp-lbl { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); font-family: 'Georgia', serif; margin-bottom: 3px; }
.dlock {
  display: none; background: var(--accent); color: #fff; padding: 6px 9px;
  font-size: 10px; font-family: Georgia; align-items: center; justify-content: space-between; gap: 6px;
}
.dlock.show { display: flex; }
.dlock .lk-name { letter-spacing: 1px; }
.dlock .lk-x { cursor: pointer; color: rgba(255,255,255,0.7); font-size: 13px; }
.dlock .lk-x:hover { color: #fff; }
.dquick { display: grid; grid-template-columns: repeat(3,1fr); gap: 4px; }
.dbtn {
  background: var(--surface2); border: 1px solid var(--border);
  color: var(--ink2); cursor: pointer; font-size: 12px;
  font-family: 'Georgia', serif; padding: 7px 4px; text-align: center; transition: all 0.1s;
}
.dbtn:hover, .dbtn.sel { background: var(--ink); border-color: var(--ink); color: white; }
.dcrow { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.dexrow { display: flex; gap: 4px; align-items: end; }
.dexrow .field { flex: 1; margin: 0; }
.dexrow input { font-family: 'Consolas', monospace; }
.dgo {
  padding: 4px 10px; border: 1px solid var(--ink);
  background: var(--ink); color: white;
  font-family: 'Georgia', serif; font-size: 10px; letter-spacing: 1px;
  text-transform: uppercase; cursor: pointer;
}
.dresult {
  background: var(--surface2); border: 1px solid var(--border);
  padding: 10px; text-align: center; min-height: 76px;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px;
}
.dresult-lbl { font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); font-family: 'Georgia', serif; }
.dresult-num { font-size: 42px; color: var(--ink); line-height: 1; font-family: 'Georgia', serif; }
.dresult-num.bump { animation: bump 0.14s ease; }
@keyframes bump { 50%{transform:scale(1.1)} }
.dresult-bk { font-size: 10px; color: var(--muted); font-family: 'Consolas', monospace; }
.dresult-ex { font-size: 9px; color: var(--border2); }
.drollbig {
  width: 100%; padding: 9px; background: var(--accent); border: none; color: white;
  font-family: 'Georgia', serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer;
}
.drollbig:hover { opacity: 0.88; }
.dhist-head {
  font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
  font-family: 'Georgia', serif; display: flex; justify-content: space-between; margin-bottom: 3px;
}
.dhist-clear { font-size: 9px; color: var(--border2); cursor: pointer; text-decoration: underline; font-family: Georgia; text-transform: none; letter-spacing: 0; }
.dhist-clear:hover { color: var(--muted); }
.dhistory { display: flex; flex-direction: column; gap: 2px; max-height: 130px; overflow-y: auto; }
.dhitem { background: var(--surface2); border: 1px solid var(--border); padding: 3px 7px; display: flex; gap: 7px; font-size: 10px; }
.dhexpr { color: var(--muted); font-family: 'Consolas', monospace; flex: 1; }
.dhval { color: var(--ink); font-family: Georgia; }
.dhtime { font-size: 9px; color: var(--border); }
.last-roll-note { font-size: 9px; color: var(--muted); text-align: center; font-style: italic; }

/* EXPORT MODAL */
.modal-bg {
  position: fixed; inset: 0; background: rgba(10,10,10,0.55);
  z-index: 1500; display: none; align-items: flex-start; justify-content: center; padding: 24px;
  overflow-y: auto;
}
.modal-bg.open { display: flex; }
.modal-card { background: #fff; width: 760px; max-width: 100%; border: 1px solid var(--border2); }
.modal-head { background: var(--rule); color: #fff; padding: 9px 16px; display: flex; justify-content: space-between; align-items: center; }
.modal-head .mt { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; }
.modal-head .mx { cursor: pointer; color: rgba(255,255,255,0.6); font-size: 16px; }
.modal-head .mx:hover { color: #fff; }
.modal-tools { padding: 10px 16px; display: flex; gap: 8px; align-items: center; border-bottom: 1px solid var(--border); background: var(--info-bg); }
.modal-tools .hint { font-size: 10px; color: var(--muted); font-style: italic; margin-left: auto; }
.modal-body { padding: 18px 22px; max-height: 70vh; overflow-y: auto; }

/* TOAST */
.toast {
  position: fixed; bottom: 14px; left: 50%; transform: translateX(-50%);
  background: var(--ink); color: white; padding: 5px 18px;
  font-family: 'Georgia', serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
  z-index: 9999; transition: opacity 0.3s; pointer-events: none;
}

@media print {
  .topbar, .dice-panel, .modal-bg { display: none !important; }
  body { background: white; padding: 5px; }
  .section-head { background: #222 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
}
</style>
</head>
<body>

<!-- DICE PANEL -->
<div class="dice-panel" id="dicePanel">
  <div class="dp-head">
    <span class="dp-title">Dice</span>
    <button class="dp-close" onclick="closeDice()" title="Close & unlock">x</button>
  </div>
  <div class="dp-body">
    <div class="dlock" id="dLock">
      <span class="lk-name" id="dLockName">Locked</span>
      <span class="lk-x" onclick="closeDice()" title="Unlock & close">x</span>
    </div>
    <div>
      <div class="dp-lbl">Quick Dice</div>
      <div class="dquick">
        <button class="dbtn" onclick="selectDie(4)">d4</button>
        <button class="dbtn" onclick="selectDie(6)">d6</button>
        <button class="dbtn" onclick="selectDie(8)">d8</button>
        <button class="dbtn" onclick="selectDie(10)">d10</button>
        <button class="dbtn" onclick="selectDie(20)">d20</button>
        <button class="dbtn" onclick="selectDie(40)">d40</button>
      </div>
    </div>
    <div class="dcrow">
      <div class="field"><label>Count</label><input type="number" id="dCount" min="1" max="20" value="1"></div>
      <div class="field"><label>Modifier</label><input type="number" id="dMod" min="-99" max="99" value="0"></div>
    </div>
    <div>
      <div class="dp-lbl">Custom Expression</div>
      <div class="dexrow">
        <div class="field"><input type="text" id="dExpr" placeholder="2d6+3" oninput="clearDieSelect()"></div>
        <button class="dgo" onclick="rollExpr()">Roll</button>
      </div>
    </div>
    <div class="dresult">
      <div class="dresult-lbl">Result</div>
      <div class="dresult-num" id="dResultNum">&mdash;</div>
      <div class="dresult-bk" id="dResultBreak"></div>
      <div class="dresult-ex" id="dResultExpr"></div>
    </div>
    <button class="drollbig" id="dRollBig" onclick="rollSelected()">Roll</button>
    <div class="last-roll-note" id="lastRollNote"></div>
    <div>
      <div class="dhist-head">History <span class="dhist-clear" onclick="clearHistory()">Clear</span></div>
      <div class="dhistory" id="dHistory"></div>
    </div>
  </div>
</div>

<!-- TOPBAR -->
<div class="topbar">
  <div class="title">W.T.E Character Sheet</div>
  <div class="topbar-right">
    <button class="btn" onclick="toggleDice()">Dice</button>
    <span class="sep">|</span>
    <button class="btn prime" onclick="openExport()">Export</button>
    <button class="btn" onclick="saveSheet()">Save</button>
    <button class="btn" onclick="loadSheet()">Load</button>
    <button class="btn" onclick="clearSheet()">Clear</button>
    <span class="sep">|</span>
    <button class="btn" onclick="window.print()">Print</button>
  </div>
</div>

<div class="sheet">

<!-- IDENTITY -->
<div class="section">
  <div class="section-head">Inquisitor Identity</div>
  <div class="section-body">
    <div class="ig1">
      <div class="field"><label>Name</label><input type="text" id="f-name"></div>
      <div class="field"><label>Rank</label><input type="number" id="f-level" min="0" max="9" value="0" oninput="onRankChange()"></div>
      <div class="field"><label>Paradigm</label>
        <select id="f-paradigm" onchange="onParadigmChange()">
          <option value="">&mdash;</option>
          <option>Science</option><option>Simulation</option><option>Remnant</option>
          <option>Cognition</option><option>Evolution</option><option>Warfare</option>
        </select>
      </div>
