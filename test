// DICE ROLLER  (with locked auto-roll context)
// ════════════════════════════════════════════════════
let selectedDie=40, rollHistory=[], lockedRoll=null;
function toggleDice(){document.getElementById('dicePanel').classList.toggle('open');}
function closeDice(){
  // X button: unlock + close, return to manual mode
  lockedRoll=null;
  document.getElementById('dLock').classList.remove('show');
  document.getElementById('dRollBig').textContent='Roll';
  document.getElementById('lastRollNote').textContent='';
  document.getElementById('dicePanel').classList.remove('open');
}
function selectDie(n){
  selectedDie=n;
  document.querySelectorAll('.dbtn').forEach(b=>b.classList.toggle('sel',b.textContent==='d'+n));
  document.getElementById('dExpr').value='';
}
function clearDieSelect(){document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('sel'));selectedDie=null;}
function rollDie(s){return Math.floor(Math.random()*s)+1;}
function parseExpr(e){
  const m=e.trim().toLowerCase().replace(/\s/g,'').match(/^(\d+)?d(\d+)([+-]\d+)?$/);
  if(!m)return null;
  return{count:parseInt(m[1]||'1'),sides:parseInt(m[2]),mod:parseInt(m[3]||'0')};
}
function rollSelected(){
  if(lockedRoll){ runLockedRoll(); return; }
  const ex=document.getElementById('dExpr').value.trim();
  if(ex){rollExpr();return;}
  const s=selectedDie||20,c=parseInt(document.getElementById('dCount').value)||1,mod=parseInt(document.getElementById('dMod').value)||0;
  performRoll(c,s,mod,`${c}d${s}${mod>0?'+'+mod:mod<0?mod:''}`,null);
}
function rollExpr(){
  const raw=document.getElementById('dExpr').value,p=parseExpr(raw);
  if(!p){toast('Invalid — e.g. 2d6+3');return;}
  performRoll(p.count,p.sides,p.mod,raw,null);
}
function openPanelIfClosed(){ if(!document.getElementById('dicePanel').classList.contains('open'))document.getElementById('dicePanel').classList.add('open'); }
function showLock(name){
  const l=document.getElementById('dLock');
  document.getElementById('dLockName').textContent='Locked: '+name+' — press Roll';
  l.classList.add('show');
  document.getElementById('dRollBig').textContent='Roll '+name;
}
// Attribute check: 1d20 + score (re-reads current score each roll)
function inlineRoll(label,scoreId){
  lockedRoll={kind:'attr',label,scoreId,sides:20};
  openPanelIfClosed(); showLock(label);
  runLockedRoll();
}
// Specialty check: 1d40 + pts; pts<=25 → -25 untrained penalty (re-reads current pts)
function inlineSpecRoll(label,specId){
  lockedRoll={kind:'spec',label,specId,sides:40};
  openPanelIfClosed(); showLock(label);
  runLockedRoll();
}
function runLockedRoll(){
  if(!lockedRoll)return;
  if(lockedRoll.kind==='attr'){
    const score=parseInt(document.getElementById(lockedRoll.scoreId)?.value)||0;
    performRoll(1,20,score,`1d20+${score}`,`${lockedRoll.label}: 1d20 + ${score}`);
  }else if(lockedRoll.kind==='spec'){
    const pts=parseInt(document.getElementById(lockedRoll.specId)?.value)||0;
    const penalty=pts<=25?-25:0;
    const mod=pts+penalty;
    const note=`${lockedRoll.label}: 1d40 + ${pts}${penalty?(' '+penalty+' untrained'):''}`;
    performRoll(1,40,mod,`1d40${mod>=0?'+'+mod:mod}`,note);
  }
}
function performRoll(count,sides,mod,exprLabel,note){
  const rolls=Array.from({length:count},()=>rollDie(sides));
  const total=rolls.reduce((a,b)=>a+b,0)+mod;
  const n=document.getElementById('dResultNum');
  n.textContent=total;n.classList.add('bump');
  setTimeout(()=>n.classList.remove('bump'),160);
  document.getElementById('dResultBreak').textContent=(count>1?'['+rolls.join(', ')+']':('['+rolls[0]+']'))+(mod?(mod>0?' +'+mod:' '+mod):'');
  document.getElementById('dResultExpr').textContent=exprLabel.replace('+0','');
  document.getElementById('lastRollNote').textContent=note||'';
  const t=new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
  rollHistory.unshift({expr:(note?note.split(':')[0]+' ':'')+exprLabel.replace('+0',''),total,t});
  if(rollHistory.length>25)rollHistory.pop();
  renderHistory();
}
function renderHistory(){
  const el=document.getElementById('dHistory');el.innerHTML='';
  rollHistory.forEach(h=>{
    const d=document.createElement('div');d.className='dhitem';
    d.innerHTML=`<span class="dhexpr">${h.expr}</span><span class="dhval">${h.total}</span><span class="dhtime">${h.t}</span>`;
    el.appendChild(d);
  });
}
function clearHistory(){
  rollHistory=[];renderHistory();
  document.getElementById('dResultNum').textContent='—';
  document.getElementById('dResultBreak').textContent='';
  document.getElementById('dResultExpr').textContent='';
  document.getElementById('lastRollNote').textContent='';
}

