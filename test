function collectAll(){
  const d={
    __asymCount:asymCount, __genusCount:genusCount,
    __varnaAbilityCount:varnaAbilityCount, __cipherCount:cipherCount,
    __stage:currentStage, __cipher:cipherStatus,
  };
  document.querySelectorAll('input,textarea,select').forEach(el=>{if(el.id)d[el.id]=el.value;});
  document.querySelectorAll('[id^="bg-b"]').forEach(el=>{d[el.id]=el.value;});
  return d;
}
function applyAll(d){
  const extraAsym=Math.max(0,(d.__asymCount||4)-4);
  for(let i=0;i<extraAsym;i++){asymCount++;document.getElementById('asym-body').appendChild(makeAsymRow(asymCount));}
  const extraGenus=Math.max(0,(d.__genusCount||5)-5);
  for(let i=0;i<extraGenus;i++){genusCount++;document.getElementById('genus-body').appendChild(makeGenusRow(genusCount));}
  const extraVarna=Math.max(0,(d.__varnaAbilityCount||4)-4);
  for(let i=0;i<extraVarna;i++){
    varnaAbilityCount++;
    const list=document.getElementById('varna-ability-list');
    const div=document.createElement('div');div.className='aitem';
    div.innerHTML=`<span class="anum">${varnaAbilityCount}.</span><input type="text" id="vs-a${varnaAbilityCount}">`;
    list.appendChild(div);
  }
  const extraCipher=Math.max(0,(d.__cipherCount||2)-2);
  for(let i=0;i<extraCipher;i++){
    cipherCount++;
    const list=document.getElementById('cipher-list');
    const div=document.createElement('div');div.className='aitem';
    div.innerHTML=`<span class="anum">${cipherCount}.</span><input type="text" id="c${cipherCount}">`;
    list.appendChild(div);
  }
  // species first so variant options exist
  if(d['f-species']){document.getElementById('f-species').value=d['f-species'];onSpeciesChange();}
  Object.entries(d).forEach(([id,val])=>{
    if(id.startsWith('__'))return;
    const el=document.getElementById(id);
    if(el&&!el.readOnly)el.value=val;
  });
  if(d['f-variant']){document.getElementById('f-variant').value=d['f-variant'];renderSpeciesAbilities();}
  if(d.__stage)setStage(d.__stage);
  if(d.__cipher)setCipherStatus(d.__cipher);
  document.querySelectorAll('[id^="bg-b"]').forEach(el=>{if(d[el.id])el.value=d[el.id];});
  onParadigmChange(); onBackgroundChange(); calcAll(); updateGenusBtn(); updateCipherBtn(); updatePEState();
}
function autosave(){localStorage.setItem('wte-sheet-v6',JSON.stringify(collectAll()));}
document.addEventListener('change',autosave);
document.addEventListener('input',e=>{
  if(e.target.classList.contains('spec-in')||e.target.id.startsWith('a-')||e.target.id.startsWith('do-'))calcAll();
  autosave();
});

function saveSheet(){
  const name=document.getElementById('f-name').value||'Inquisitor';
  const blob=new Blob([JSON.stringify(collectAll(),null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download=`WTE_${name.replace(/\s+/g,'_')}.json`;a.click();toast('Saved.');
}
function loadSheet(){
  const inp=document.createElement('input');inp.type='file';inp.accept='.json';
  inp.onchange=e=>{
    const r=new FileReader();
    r.onload=ev=>{try{applyAll(JSON.parse(ev.target.result));toast('Loaded.');}catch(er){toast('Error.');}};
    r.readAsText(e.target.files[0]);
  };inp.click();
}
function clearSheet(){
  if(!confirm('Clear all data?'))return;
  document.querySelectorAll('input:not([readonly]),textarea').forEach(el=>el.value='');
  document.querySelectorAll('select').forEach(el=>el.selectedIndex=0);
  document.querySelectorAll('.spec-in').forEach(el=>el.value='0');
  document.getElementById('i-nature').dataset.auto='';document.getElementById('i-ability').dataset.auto='';
  setStage('');setCipherStatus('active');
  document.getElementById('species-box').classList.remove('visible');
  document.getElementById('paradigm-box').classList.remove('visible');
  document.getElementById('bg-bonus-box').classList.remove('visible');
  document.getElementById('pe-val').value=50;
  onSpeciesChange();
  calcAll();updateGenusBtn();updateCipherBtn();toast('Cleared.');
}
function toast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.style.opacity='1';
  setTimeout(()=>t.style.opacity='0',1700);
}

