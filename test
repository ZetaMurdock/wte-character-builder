  SPECS.forEach((s,i)=>{
    const pts=val(s[0])||'0', mod=val('sm-'+s[0].slice(2));
    html+=`<td style="padding:4px 8px;border:1px solid ${C.line};font-size:11px;"><span style="font-size:8px;letter-spacing:1px;text-transform:uppercase;color:${C.mut};display:block;">${s[1]}</span><b>${esc(pts)}</b> <span style="color:${C.mut};">(mod ${esc(mod)})</span></td>`;
    if(i%4===3)html+=`</tr><tr>`;
  });
  html+=`</tr></table>`;

  // species abilities
  if(sp&&SPECIES_DATA[sp]){
    html+=sectionHead('Incept — Species & Abilities');
    html+=`<div style="font-size:12px;line-height:1.7;">`;
    html+=`<b>Family:</b> ${esc(SPECIES_DATA[sp].family)}<br>`;
    html+=`<b>Innate:</b> ${esc(SPECIES_DATA[sp].innate.join(' &middot; '))}<br>`;
    if(variant&&SPECIES_DATA[sp].variants[variant]) html+=`<b>${esc(variant)}:</b> ${esc(SPECIES_DATA[sp].variants[variant].join(' &middot; '))}<br>`;
    if(val('i-wryde'))html+=`<b>Wryde:</b> ${esc(val('i-wryde'))}<br>`;
    html+=`<b>Stage:</b> ${esc(currentStage||'—')} &middot; <b>Expression:</b> ${esc(val('i-expr'))}`;
    html+=`</div>`;
  }

  // asymmetry log
  let asymRows='';
  for(let i=1;i<=asymCount;i++){
    if(!document.getElementById('as-name-'+i))continue;
    const nm=val('as-name-'+i);if(!nm&&!val('as-fx-'+i))continue;
    asymRows+=`<tr>${cell('Domain',val('as-dom-'+i))}${cell('Name',nm)}${cell('Weight',val('as-wt-'+i))}${cell('Wryde',val('as-wr-'+i))}${cell('Effect',val('as-fx-'+i))}</tr>`;
  }
  if(asymRows){ html+=sectionHead('Asymmetry Log'); html+=`<table style="border-collapse:collapse;width:100%;">${asymRows}</table>`; }

  // genus
  let genusRows='';
  for(let i=1;i<=genusCount;i++){
    if(!document.getElementById('gn-name-'+i))continue;
    const nm=val('gn-name-'+i);if(!nm)continue;
    genusRows+=`<tr>${cell('Name',nm)}${cell('Domain',val('gn-dom-'+i))}${cell('Action',val('gn-act-'+i))}${cell('SS',val('gn-ss-'+i))}${cell('Effect',val('gn-fx-'+i))}</tr>`;
  }
  if(genusRows){ html+=sectionHead('Genus Loadout'); html+=`<table style="border-collapse:collapse;width:100%;">${genusRows}</table>`; }

  // varna
  if(val('v-weapon')||val('vs-path')){
    html+=sectionHead('Varna — Mastery');
    html+=`<table style="border-collapse:collapse;width:100%;"><tr>${cell('Weapon / Technique',val('v-weapon'))}${cell('Proficiency',val('v-prof'))}${cell('Weapon Skill',val('v-skill'))}${cell('Passive',val('v-passive'))}</tr>
      <tr>${cell('Mastery Path',val('vs-path'))}${cell('Save Bonus',val('vs-save'))}${cell('Hit Die',val('vs-hd'))}${cell('',' ')}</tr></table>`;
    let mab=[];for(let i=1;i<=varnaAbilityCount;i++){const v=val('vs-a'+i);if(v)mab.push(v);}
    if(mab.length)html+=`<div style="font-size:12px;margin-top:4px;"><b>Mastery Abilities:</b> ${esc(mab.join(' &middot; '))}</div>`;
  }

  // cipher
  if(val('c-tl')||val('c-benefits')){
    html+=sectionHead('Paradigm Cipher');
    html+=`<table style="border-collapse:collapse;width:100%;"><tr>${cell('Type',val('c-type'))}${cell('TL',val('c-tl'))}${cell('Status',cipherStatus)}</tr></table>`;
    if(val('c-benefits'))html+=`<div style="font-size:12px;margin-top:4px;">${esc(val('c-benefits'))}</div>`;
  }

  // equipment
  let wpns='';
  for(let i=1;i<=4;i++){const nm=val('w'+i+'-name');if(!nm)continue;wpns+=`<tr>${cell('Weapon',nm)}${cell('Type',val('w'+i+'-type'))}${cell('Damage',val('w'+i+'-dmg'))}</tr>`;}
  if(wpns||val('armor-name')){
    html+=sectionHead('Equipment');
    html+=`<table style="border-collapse:collapse;width:100%;">${wpns}`;
    if(val('armor-name'))html+=`<tr>${cell('Armor',val('armor-name'))}${cell('DR',val('armor-dr'))}${cell('',' ')}</tr>`;
    html+=`</table>`;
    const gear=[1,2,3,4].map(i=>val('gear'+i)).filter(Boolean);
    if(gear.length)html+=`<div style="font-size:12px;margin-top:4px;"><b>Gear:</b> ${esc(gear.join(' &middot; '))}</div>`;
  }

  // notes
  if(val('notes')){ html+=sectionHead('Notes & Backstory'); html+=`<div style="font-size:12px;line-height:1.6;white-space:pre-wrap;">${esc(val('notes'))}</div>`; }

  html+=`<div style="border-top:1px solid ${C.line};margin-top:18px;padding-top:6px;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:${C.mut};text-align:center;">WTE &middot; Year 3261</div>`;
  html+=`</div>`;
  return html;
}
function buildExportText(){
  const L=[];const line=(s='')=>L.push(s);
  const name=val('f-name')||'Unnamed Inquisitor';
  line('W.T.E · INQUISITOR RECORD · YEAR 3261');line('='.repeat(50));
  line(name.toUpperCase());
  line(`${val('f-species')}${val('f-variant')?(' — '+val('f-variant')):''} · ${val('f-paradigm')||'—'} · Rank ${val('f-level')||'0'}`);line('');
  line('IDENTITY');
  line(`  Background: ${val('f-background')||'—'}   CAS: ${val('f-cas')}`);
  line(`  Family: ${val('f-family')||'—'}   Player: ${val('f-player')||'—'}`);line('');
  line('ATTRIBUTES');
  ATTRS.forEach(a=>line(`  ${a[1].padEnd(5)} ${String(val(a[0])||'0').padStart(3)}   mod ${val('m-'+a[0].slice(2))}`));line('');
  line('DERIVED');
  [['Attack Power','d-atk'],['Def. HP','d-dhp'],['Movement','d-mv'],['Synaptic Space','d-ss'],['Evasion','d-ev'],['Neuronal Cap.','d-nc'],['Recovery','d-rr'],['Action Density','d-ad'],['Influence','d-inf'],['Perception','d-pr']].forEach(d=>line(`  ${d[0].padEnd(16)} ${val(d[1])||'0'}`));
  line(`  Max HP ${val('d-hpmax')||'0'}`);line('');
  line('SPECIALTIES (225 pts)');
  SPECS.forEach(s=>line(`  ${s[1].padEnd(14)} ${String(val(s[0])||'0').padStart(3)}   mod ${val('sm-'+s[0].slice(2))}`));line('');
  if(val('notes')){line('NOTES');line('  '+val('notes'));}
  return L.join('\n');
}
function openExport(){
  document.getElementById('exportRender').innerHTML=buildExportHTML();
  document.getElementById('exportModal').classList.add('open');
}
function closeExport(){document.getElementById('exportModal').classList.remove('open');}
function copyExport(){
  const node=document.getElementById('exportRender');
  const range=document.createRange();range.selectNodeContents(node);
  const sel=window.getSelection();sel.removeAllRanges();sel.addRange(range);
  let ok=false;try{ok=document.execCommand('copy');}catch(e){}
  sel.removeAllRanges();
  if(ok){toast('Copied — paste into Google Docs');}
  else{
    // Clipboard API fallback (rich)
    try{
      const blob=new Blob([node.innerHTML],{type:'text/html'});
      const tb=new Blob([buildExportText()],{type:'text/plain'});
      navigator.clipboard.write([new ClipboardItem({'text/html':blob,'text/plain':tb})]).then(()=>toast('Copied — paste into Google Docs')).catch(()=>toast('Copy failed — select manually'));
    }catch(e){toast('Copy failed — select manually');}
  }
}
function copyExportText(){
  const txt=buildExportText();
  if(navigator.clipboard){navigator.clipboard.writeText(txt).then(()=>toast('Plain text copied')).catch(()=>fallbackText(txt));}
  else fallbackText(txt);
}
function fallbackText(txt){
  const ta=document.createElement('textarea');ta.value=txt;document.body.appendChild(ta);ta.select();
  try{document.execCommand('copy');toast('Plain text copied');}catch(e){toast('Copy failed');}
  document.body.removeChild(ta);
}
document.getElementById('exportModal').addEventListener('click',e=>{if(e.target.id==='exportModal')closeExport();});

