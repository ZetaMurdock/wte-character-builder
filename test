}
function buildInitialRows() {
  const ab=document.getElementById('asym-body');
  for(let i=1;i<=4;i++){asymCount++;ab.appendChild(makeAsymRow(i));}
  const gb=document.getElementById('genus-body');
  for(let i=1;i<=5;i++){genusCount++;gb.appendChild(makeGenusRow(i));}
}
function addAsymRow() {
  asymCount++;
  document.getElementById('asym-body').appendChild(makeAsymRow(asymCount));
  autosave();
}
function addGenusRow() {
  const rank=parseInt(document.getElementById('f-level').value)||0;
  const max=5+rank;
  if(genusCount>=max){toast('Genus limit for Rank '+rank+' reached ('+max+')');return;}
  genusCount++;
  document.getElementById('genus-body').appendChild(makeGenusRow(genusCount));
  updateGenusBtn();
  autosave();
}
function addVarnaAbility(){
  varnaAbilityCount++;
  const list=document.getElementById('varna-ability-list');
  const d=document.createElement('div');d.className='aitem';
  d.innerHTML=`<span class="anum">${varnaAbilityCount}.</span><input type="text" id="vs-a${varnaAbilityCount}">`;
  list.appendChild(d); autosave();
}
function addCipher(){
  const rank=parseInt(document.getElementById('f-level').value)||0;
  const max=1+rank;
  if(cipherCount>max){toast('Cipher limit for Rank '+rank+' reached');return;}
  cipherCount++;
  const list=document.getElementById('cipher-list');
  const d=document.createElement('div');d.className='aitem';
  d.innerHTML=`<span class="anum">${cipherCount}.</span><input type="text" id="c${cipherCount}">`;
  list.appendChild(d); updateCipherBtn(); autosave();
}
function updateGenusBtn(){
  const rank=parseInt(document.getElementById('f-level').value)||0;
  const max=5+rank;
  const btn=document.getElementById('add-genus-btn');
  btn.textContent=`+ Add Genus (${genusCount}/${max})`;
  btn.disabled=genusCount>=max;
}
function updateCipherBtn(){
  const rank=parseInt(document.getElementById('f-level').value)||0;
  const max=1+rank;
  const btn=document.getElementById('add-cipher-btn');
  btn.textContent=`+ Add Cipher (${cipherCount}/${max})`;
  btn.disabled=cipherCount>max;
}

// ════════════════════════════════════════════════════
// SPECIES
// ════════════════════════════════════════════════════
function onSpeciesChange(){
  const sp=document.getElementById('f-species').value;
  const box=document.getElementById('species-box');
  const varSel=document.getElementById('f-variant');
  // rebuild variant options
  varSel.innerHTML='<option value="">&mdash;</option>';
  if(!sp||!SPECIES_DATA[sp]){box.classList.remove('visible');renderSpeciesAbilities();calcAll();autosave();return;}
  const d=SPECIES_DATA[sp];
  Object.keys(d.variants).forEach(v=>{
    const o=document.createElement('option');o.value=v;o.textContent=v;varSel.appendChild(o);
  });
  box.classList.add('visible');
  document.getElementById('sp-family').textContent=d.family;
  document.getElementById('sp-note').textContent=d.note?('— '+d.note):'';
  // bonus tags
  const bt=document.getElementById('sp-bonus-tags');bt.innerHTML='';
  const labels={'a-phy':'PHY','a-dex':'DEX','a-end':'END','a-ap':'AP','a-wis':'WIS','a-con':'CON','a-int':'INT'};
  if(Object.keys(d.bonus).length){
    Object.entries(d.bonus).forEach(([id,v])=>{
      const s=document.createElement('span');s.className='sbtag';s.innerHTML=`${labels[id]} <b>+${v}</b>`;bt.appendChild(s);
    });
  }else{
    const s=document.createElement('span');s.className='sbtag';s.textContent='No fixed attribute bonus';bt.appendChild(s);
  }
  // innate abilities chips
  const innate=document.getElementById('sp-innate');innate.innerHTML='';
  d.innate.forEach(a=>{const c=document.createElement('span');c.className='ability-chip';c.textContent=a;innate.appendChild(c);});
  // auto-fill incept prompts
  const natEl=document.getElementById('i-nature');
  if(!natEl.value || natEl.dataset.auto==='1'){ natEl.value=`${sp} (${d.family})`; natEl.dataset.auto='1'; }
  const abEl=document.getElementById('i-ability');
  if(!abEl.value || abEl.dataset.auto==='1'){ abEl.value=d.innate.join('; '); abEl.dataset.auto='1'; }
  renderSpeciesAbilities();
  calcAll(); autosave();
}
function onVariantChange(){
  document.getElementById('i-ability').dataset.auto='1'; // allow re-fill
  renderSpeciesAbilities();
  // append variant abilities into the species ability prompt if auto
  const sp=document.getElementById('f-species').value;
  const v=document.getElementById('f-variant').value;
  const abEl=document.getElementById('i-ability');
  if(SPECIES_DATA[sp]){
    const base=SPECIES_DATA[sp].innate.join('; ');
    const va=(v&&SPECIES_DATA[sp].variants[v])?(' || '+v+': '+SPECIES_DATA[sp].variants[v].join('; ')):'';
    if(abEl.dataset.auto==='1') abEl.value=base+va;
  }
  autosave();
}
function renderSpeciesAbilities(){
  const sp=document.getElementById('f-species').value;
  const v=document.getElementById('f-variant').value;
  const lbl=document.getElementById('sp-variant-lbl');
  const box=document.getElementById('sp-variant-abilities');box.innerHTML='';
  if(sp&&v&&SPECIES_DATA[sp]&&SPECIES_DATA[sp].variants[v]){
    lbl.style.display='block';lbl.firstChild.textContent='';
    lbl.innerHTML='Variant Abilities &mdash; '+v;
    SPECIES_DATA[sp].variants[v].forEach(a=>{const c=document.createElement('span');c.className='ability-chip variant';c.textContent=a;box.appendChild(c);});
  }else{ lbl.style.display='none'; }
}
function getSpeciesBonus(){
  const sp=document.getElementById('f-species').value;
  return (sp&&SPECIES_DATA[sp])?SPECIES_DATA[sp].bonus:{};
}

// ════════════════════════════════════════════════════
// PARADIGM & BACKGROUND
// ════════════════════════════════════════════════════
function onParadigmChange(){
  const p=document.getElementById('f-paradigm').value;
  const box=document.getElementById('paradigm-box');
  if(!p||!PARADIGM_DATA[p]){box.classList.remove('visible');return;}
  box.classList.add('visible');
  const d=PARADIGM_DATA[p];
  const rank=parseInt(document.getElementById('f-level').value)||0;
  const titleIdx=Math.min(rank,d.titles.length-1);
  document.getElementById('pi-title').textContent=d.titles[titleIdx]||d.titles[d.titles.length-1];
  document.getElementById('pi-light').textContent=d.weapons.Light;
  document.getElementById('pi-medium').textContent=d.weapons.Medium;
  document.getElementById('pi-heavy').textContent=d.weapons.Heavy;
  document.getElementById('pi-domains').textContent=d.domains.join(', ');
  document.getElementById('wpn-hint').textContent=
    `${p} Paradigm — Light: ${d.weapons.Light} · Medium: ${d.weapons.Medium} · Heavy: ${d.weapons.Heavy}`;
  calcAll(); autosave();
}
function onBackgroundChange(){
  const bg=document.getElementById('f-background').value;
  const box=document.getElementById('bg-bonus-box');
  if(!bg){box.classList.remove('visible');return;}
  box.classList.add('visible');
  renderBgBonuses();
}
function renderBgBonuses(){
  const type=document.getElementById('bg-type').value;
  const arr=type==='focused'?BG_FOCUSED:BG_STANDARD;
  const row=document.getElementById('bg-bonus-row');
  const saved=[];
  row.querySelectorAll('select').forEach(s=>saved.push(s.value));
  row.innerHTML='';
  arr.forEach((bonus,i)=>{
    const div=document.createElement('div');div.className='bg-bonus-item';
    const optHtml=STAT_OPTIONS.map(o=>`<option value="${o.id}"${saved[i]===o.id?' selected':''}>${o.label}</option>`).join('');
    div.innerHTML=`<span class="bg-bonus-val">+${bonus}</span>
      <select id="bg-b${i}" onchange="calcAll()">${optHtml}</select>`;
    row.appendChild(div);
  });
  calcAll();
}
function getBgBonuses(){
  const bonuses={};
  const type=document.getElementById('bg-type').value;
  const arr=type==='focused'?BG_FOCUSED:BG_STANDARD;
  arr.forEach((bonus,i)=>{
    const sel=document.getElementById('bg-b'+i);
    if(sel){const id=sel.value;bonuses[id]=(bonuses[id]||0)+bonus;}
  });
  return bonuses;
}

// ════════════════════════════════════════════════════
// RANK
// ════════════════════════════════════════════════════
function rankMult(){ const rank=parseInt(document.getElementById('f-level').value)||0; return 1+rank*0.5; }
function onRankChange(){
  calcAll(); onParadigmChange(); updateGenusBtn(); updateCipherBtn(); updateRankBar();
}
function updateRankBar(){
  const rank=parseInt(document.getElementById('f-level').value)||0;
  const paradigm=document.getElementById('f-paradigm').value;
  const d=PARADIGM_DATA[paradigm];
  const title=d?d.titles[Math.min(rank,d.titles.length-1)]:'—';
  document.getElementById('rb-rank').textContent=rank;
  document.getElementById('rb-title').textContent=title;
  document.getElementById('rb-genus').textContent=5+rank;
  document.getElementById('rb-ciphers').textContent=1+rank;
  document.getElementById('rb-hp').textContent=document.getElementById('d-hpmax').value||'—';
  document.getElementById('rb-mult').textContent='×'+rankMult().toFixed(1);
  document.getElementById('pe-mult').textContent='×'+rankMult().toFixed(1);
}

// ════════════════════════════════════════════════════
// CALCULATIONS
// ════════════════════════════════════════════════════
function getV(id){return parseInt(document.getElementById(id)?.value)||0;}
function setRO(id,val){const el=document.getElementById(id);if(el&&el.readOnly)el.value=val;}

function calcAll(){
  const bg=getBgBonuses();
  const spb=getSpeciesBonus();
  const ab=(id)=>(bg[id]||0)+(spb[id]||0); // total external bonus for a stat
  const raw={
    phy:getV('a-phy')+ab('a-phy'),
    dex:getV('a-dex')+ab('a-dex'),
    end:getV('a-end')+ab('a-end'),
    ap: getV('a-ap') +ab('a-ap'),
    wis:getV('a-wis')+ab('a-wis'),
    con:getV('a-con')+ab('a-con'),
    int:getV('a-int')+ab('a-int'),
  };
  const m={};
  ['phy','dex','end','ap','wis','con','int'].forEach(a=>{
    m[a]=Math.floor(raw[a]/4);
    setRO('m-'+a, m[a]);
  });
  // attribute bonus note
  const totalSpB=Object.values(spb).reduce((x,y)=>x+y,0);
  document.getElementById('attr-bonus-note').textContent=totalSpB?('+ species bonus'):'';

  // Specialties (with background bonuses, capped at SPEC_MAX)
  const sp={
    ins:Math.min(SPEC_MAX,getV('s-ins')+(bg['s-ins']||0)),
    ver:Math.min(SPEC_MAX,getV('s-ver')+(bg['s-ver']||0)),
    bal:Math.min(SPEC_MAX,getV('s-bal')+(bg['s-bal']||0)),
    wt: Math.min(SPEC_MAX,getV('s-wt') +(bg['s-wt'] ||0)),
    pre:Math.min(SPEC_MAX,getV('s-pre')+(bg['s-pre']||0)),
    ctrl:Math.min(SPEC_MAX,getV('s-ctrl')+(bg['s-ctrl']||0)),
    pri:Math.min(SPEC_MAX,getV('s-pri')+(bg['s-pri']||0)),
    wm: Math.min(SPEC_MAX,getV('s-wm') +(bg['s-wm'] ||0)),
    mf: Math.min(SPEC_MAX,getV('s-mf') +(bg['s-mf'] ||0)),
    per:Math.min(SPEC_MAX,getV('s-per')+(bg['s-per']||0)),
    adp:Math.min(SPEC_MAX,getV('s-adp')+(bg['s-adp']||0)),
    cun:Math.min(SPEC_MAX,getV('s-cun')+(bg['s-cun']||0)),
  };
  const sm={};
  const spKeys=['ins','ver','bal','wt','pre','ctrl','pri','wm','mf','per','adp','cun'];
  const spIds=['s-ins','s-ver','s-bal','s-wt','s-pre','s-ctrl','s-pri','s-wm','s-mf','s-per','s-adp','s-cun'];
  spKeys.forEach((k,i)=>{ sm[k]=Math.floor(sp[k]/10)*2; setRO('sm-'+spIds[i].slice(2),sm[k]); });

  const red=(pts)=>Math.floor(pts/RED_DIV);    // reduction: −1 per RED_DIV pts
  // DERIVED STAT — STEP 1: subtotal = 5 + full value of each contributing stat.
  // STEP 2: maximum = subtotal + 2 per full 10 points of that subtotal.
  // STEP 3: subtract reductions last — NO floor, so it can hit 0 or go negative.
  //   e.g. END 20 + Weight 25 → subtotal 50 → +10 → 60 max → minus reductions.
  const dv=(contribs, reductions)=>{
    const S = 5 + contribs;                    // subtotal incl. base +5
    const max = S + Math.floor(S/10)*2;        // +2 per 10 points of the subtotal
    return max - (reductions||0);              // overload it and it goes negative
  };
  // Every specialty now both helps (full-value contributor) and hinders (reducer).
  const atk = dv(raw.phy + sp.wt + sp.ctrl,           red(sp.pre) + red(sp.bal));
  const dhp = dv(sp.wt + raw.end,                      red(sp.adp) + red(sp.cun));
  const mv  = dv(raw.dex + raw.ap + sp.pri,            red(sp.wt) + red(sp.pre));
  const ss  = dv(sp.mf + raw.int + sp.adp,             red(sp.ver) + red(sp.pri));
  const ev  = dv(raw.dex + sp.bal + sp.cun,            red(sp.wt) + red(sp.mf));
  const nc  = dv(sp.adp + sp.mf + raw.wis + sp.ver,    red(sp.ctrl) + red(sp.wm));
  const rr  = dv(raw.end + sp.bal + sp.adp,            red(sp.wt) + red(sp.ctrl) + red(sp.cun));
  const ad  = dv(raw.ap + sp.pre + sp.cun + sp.pri,    red(sp.wt) + red(sp.mf));
  const inf = dv(raw.con + sp.cun + sp.ins + sp.ver,   red(sp.adp) + red(sp.per));
  const pr  = dv(raw.wis + sp.per + sp.cun,            red(sp.mf) + red(sp.bal));

  const ov=(id)=>parseInt(document.getElementById(id)?.value)||0;
  // No clamp — a badly-built stat shows its true 0 or negative value as a liability.
  setRO('d-atk', atk+ov('do-atk'));
  setRO('d-dhp', dhp+ov('do-dhp'));
  setRO('d-mv',  mv +ov('do-mv'));
  setRO('d-ss',  ss +ov('do-ss'));
  setRO('d-ev',  ev +ov('do-ev'));
  setRO('d-nc',  nc +ov('do-nc'));
  setRO('d-rr',  rr +ov('do-rr'));
  setRO('d-ad',  ad +ov('do-ad'));
  setRO('d-inf', inf+ov('do-inf'));
  setRO('d-pr',  pr +ov('do-pr'));

  // HP = floor((DHP/2) × rankMult) + END mod (HP itself still bottoms out at 0 = death)
  const dhpVal = dhp+ov('do-dhp');
  const hpMax  = Math.floor((dhpVal/2)*rankMult()) + m.end;
  setRO('d-hpmax', hpMax>0?hpMax:0);

  // Points remaining (raw, before caps/bonuses)
  let total=0;
  document.querySelectorAll('.spec-in').forEach(el=>total+=parseInt(el.value)||0);
  const left=SPEC_TOTAL-total;
  const el=document.getElementById('pts-left');
  el.textContent=left; el.style.color=left<0?'#b03020':'';

  // Pressure Engine derived: Tax Burden & Complexity
  let tax=0; REDUCERS.forEach(id=>tax+=Math.floor((getV(id)+(bg[id]||0))/10));
  const inspPts=Math.min(SPEC_MAX,getV('s-ins')+(bg['s-ins']||0));
  const complexity=inspPts-tax;
  document.getElementById('pe-cplx').textContent=(complexity>=0?'+':'')+complexity;

  updateRankBar();
  updatePEState();
}

