function buildPESkills(){
  const wrap=document.getElementById('pe-skills');wrap.innerHTML='';
  for(let i=1;i<=4;i++){
    const row=document.createElement('div');row.className='pe-skill-row';
    const spOpts='<option value="">— skill —</option>'+SPECS.map(s=>`<option value="${s[0]}">${s[1]}</option>`).join('');
    const atOpts='<option value="">no attr</option>'+ATTRS.map(a=>`<option value="${a[0]}">${a[1]}</option>`).join('');
    row.innerHTML=`<div class="rl">${i}</div>
      <select id="pe-sp-${i}" onchange="autosave()">${spOpts}</select>
      <select id="pe-at-${i}" onchange="autosave()">${atOpts}</select>
      <div class="pe-roll-out" id="pe-r-${i}">&mdash;</div>`;
    wrap.appendChild(row);
  }
}
function updatePEState(){
  const v=parseInt(document.getElementById('pe-val').value)||0;
  const el=document.getElementById('pe-state');
  let s='CALM',c='calm';
  if(v>=110){s='CATASTROPHIC';c='catastrophic';}
  else if(v>=80){s='CRITICAL';c='critical';}
  else if(v>=45){s='TENSE';c='tense';}
  el.textContent=s; el.className='pe-state '+c;
}
function resolvePE(){
  const complexity=parseInt(document.getElementById('pe-cplx').textContent)||0;
  const mult=rankMult();
  let totals=[],used=0;
  for(let i=1;i<=4;i++){
    const spId=document.getElementById('pe-sp-'+i).value;
    const out=document.getElementById('pe-r-'+i);
    if(!spId){ out.textContent='—'; continue; }
    used++;
    const specPts=getV(spId);
    const atId=document.getElementById('pe-at-'+i).value;
    const attrMod=atId?(parseInt(document.getElementById('m-'+atId.slice(2)).value)||0):0;
    const die=Math.floor(Math.random()*40)+1;
    const raw=(die+specPts+attrMod+complexity)*mult;
    const tot=Math.round(raw);
    totals.push(tot);
    out.textContent=`${tot} (d40=${die})`;
  }
  const res=document.getElementById('pe-result');
  if(used===0){ res.classList.remove('show'); toast('Select at least 1 skill'); return; }
  const cBonus = used>=4?2 : used===3?1 : 0;
  const avg = totals.reduce((a,b)=>a+b,0)/used;
  const aav = Math.round(avg)+cBonus;
  const pe=parseInt(document.getElementById('pe-val').value)||0;
  const diff=aav-pe;
  document.getElementById('pe-aav').textContent=aav+(cBonus?` (+${cBonus})`:'');
  document.getElementById('pe-diff').textContent=(diff>=0?'+':'')+diff;
  const band=peBand(diff);
  const o=document.getElementById('pe-outcome');
  o.textContent=band.name; o.style.color=band.color;
  document.getElementById('pe-change').textContent=(band.change>=0?'+':'')+band.change+'  ('+band.range+')';
  res.dataset.change=band.change;
  res.classList.add('show');
  toast(band.name);
}
function peBand(diff){
  if(diff>=6)   return {name:'CRITICAL SUCCESS', color:'#2f7a45', change:-8, range:'−6 to −10'};
  if(diff>=4)   return {name:'SUCCESS',          color:'#4e7fa5', change:-4, range:'−4'};
  if(diff>=2)   return {name:'SIMPLE SUCCESS',   color:'#3d3c39', change:-2, range:'−2'};
  if(diff>=-1)  return {name:'PARTIAL / STALEMATE', color:'#b88a20', change:0, range:'0'};
  if(diff>=-3)  return {name:'FUMBLE',           color:'#c07030', change:2, range:'+1 to +2'};
  if(diff>=-5)  return {name:'FAILURE',          color:'#a03535', change:4, range:'+3 to +5'};
  return            {name:'CRITICAL FAILURE',color:'#7a1a1a', change:8, range:'+5 to +10'};
}
function applyPEChange(){
  const res=document.getElementById('pe-result');
  const ch=parseInt(res.dataset.change)||0;
  const pe=parseInt(document.getElementById('pe-val').value)||0;
  document.getElementById('pe-val').value=Math.max(0,pe+ch);
  updatePEState(); res.classList.remove('show'); autosave();
  toast('PE → '+document.getElementById('pe-val').value);
}
function resetPESkills(){
  for(let i=1;i<=4;i++){ document.getElementById('pe-sp-'+i).value=''; document.getElementById('pe-at-'+i).value=''; document.getElementById('pe-r-'+i).textContent='—'; }
  document.getElementById('pe-result').classList.remove('show'); autosave();
}

