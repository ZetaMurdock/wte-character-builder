];

const SPEC_TOTAL = 225, SPEC_MAX = 75;
// ── DERIVED-STAT BALANCE KNOBS (tweak these to rebalance build-crafting) ──
const RED_DIV = 3;        // reduction harshness: −1 per this many specialty pts (lower = harsher)
                          // no safety floor — a bad build can drop a derived stat to 0 or negative

// ════════════════════════════════════════════════════
// DYNAMIC ROWS
// ════════════════════════════════════════════════════
let asymCount = 0, genusCount = 0, varnaAbilityCount = 4, cipherCount = 2;

function makeAsymRow(n) {
  const tr = document.createElement('tr'); tr.id='asym-row-'+n;
  tr.innerHTML=`<td class="rn">${n}</td>
    <td><select id="as-dom-${n}" style="font-size:11px;"><option value="">&mdash;</option><option>Genera</option><option>Incept</option><option>Varna</option><option>Uber</option></select></td>
    <td><input type="text" id="as-name-${n}"></td>
    <td><input type="text" id="as-wt-${n}"></td>
    <td><input type="text" id="as-wr-${n}"></td>
    <td><input type="text" id="as-fx-${n}"></td>`;
  return tr;
}
function makeGenusRow(n) {
  const tr = document.createElement('tr'); tr.id='genus-row-'+n;
  tr.innerHTML=`<td class="rn">${n}</td>
    <td><input type="text" id="gn-name-${n}"></td>
    <td><select id="gn-dom-${n}" style="font-size:11px;"><option value="">&mdash;</option><option>Neutral</option><option>Eldritch</option><option>Null</option><option>Elemental</option><option>Kinetic</option></select></td>
    <td><input type="text" id="gn-act-${n}"></td>
    <td><input type="number" id="gn-ss-${n}" min="0"></td>
    <td><textarea id="gn-fx-${n}" style="min-height:22px;"></textarea></td>`;
